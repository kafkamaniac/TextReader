<Window x:Class="TextReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:TextReader"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800"
        Closing="Window_Closing"
        Background="{DynamicResource WindowBackground}">

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">

                <MenuItem Header="Создать"
                  Click="New_Click"/>

                <MenuItem Header="Открыть"
                  Click="Open_Click"/>

                <MenuItem Header="Сохранить"
                  Click="Save_Click"/>

            </MenuItem>

            <MenuItem Header="Настройки"
              Click="Settings_Click"/>
        </Menu>
        
        <StackPanel Orientation="Horizontal"
            DockPanel.Dock="Top"
            Background="LightGray">

            <Button Content="B"
            FontWeight="Bold"
            Width="30"
            Click="Bold_Click"/>

            <Button Content="I"
            FontStyle="Italic"
            Width="30"
            Click="Italic_Click"/>

            <Button Content="U"
            Width="30"
            Click="Underline_Click"/>

            <Button Content="S"
            Width="30"
            Click="Strike_Click"/>

            <Button Width="30"
        Click="AlignLeft_Click"
        ToolTip="По левому краю">
                <StackPanel>
                    <Rectangle Height="2" Width="16" Fill="Black"/>
                    <Rectangle Height="2" Width="12" Fill="Black" Margin="0,2,4,0"/>
                    <Rectangle Height="2" Width="10" Fill="Black" Margin="0,2,6,0"/>
                    <Rectangle Height="2" Width="8" Fill="Black" Margin="0,2,8,0"/>
                </StackPanel>
            </Button>

            <Button Width="30"
        Click="AlignCenter_Click">
                <StackPanel HorizontalAlignment="Center">
                    <Rectangle Height="2" Width="16" Fill="Black"/>
                    <Rectangle Height="2" Width="10" Fill="Black" Margin="0,2,0,0"/>
                    <Rectangle Height="2" Width="16" Fill="Black" Margin="0,2,0,0"/>
                    <Rectangle Height="2" Width="10" Fill="Black" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <Button Width="30"
                    
        Click="AlignRight_Click"
        ToolTip="По правому краю">
                <StackPanel HorizontalAlignment="Right">
                    <Rectangle Height="2" Width="16" Fill="Black"/>
                    <Rectangle Height="2" Width="12" Fill="Black" Margin="4,2,0,0"/>
                    <Rectangle Height="2" Width="10" Fill="Black" Margin="6,2,0,0"/>
                    <Rectangle Height="2" Width="8" Fill="Black" Margin="8,2,0,0"/>
                </StackPanel>
            </Button>

            <Button Width="30"
        Click="Justify_Click"
        ToolTip="По ширине">
                <StackPanel>
                    <Rectangle Height="2" Width="16" Fill="Black"/>
                    <Rectangle Height="2" Width="16" Fill="Black" Margin="0,2,0,0"/>
                    <Rectangle Height="2" Width="16" Fill="Black" Margin="0,2,0,0"/>
                    <Rectangle Height="2" Width="16" Fill="Black" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <TextBlock Text="Размер:"
                       VerticalAlignment="Center"
                       Margin="5,0"/>
            <ComboBox x:Name="FontSizeBox"
                      Width="60"
                      IsEditable="True"
                      SelectionChanged="FontSize_Changed"
                      LostFocus="FontSize_LostFocus"
                      KeyDown="FontSize_KeyDown"/>

            <TextBlock Text="Шрифт:"
                       VerticalAlignment="Center"
                       Margin="5,0"/>
            <ComboBox x:Name="FontFamilyBox"
                      Width="200"
                      SelectionChanged="FontFamily_Changed"/>

            <TextBlock Text="Цвет:"
                       VerticalAlignment="Center"
                       Margin="5,0"/>
            <xctk:ColorPicker x:Name="ColorPickerBox"
                  Width="120"
                  SelectedColorChanged="ColorPicker_Changed"/>

            <Button x:Name="ModeButton"
                    Content="Режим чтения"
                    Click="ModeButton_Click"/>

        </StackPanel>
        
        <StackPanel Margin="20">

            <TextBox x:Name="InputTextBox"
             Width="200"
             Margin="0,0,0,10"/>

            <Button Content="Перевести"
            Width="200"
            Click="Translate_Click"/>

            <TextBlock x:Name="ResultTextBlock"
               Margin="0,10,0,0"
               FontSize="16"/>
        </StackPanel>
        
        <RichTextBox x:Name="Editor"
             Background="{DynamicResource EditorBackground}"
             Foreground="{DynamicResource EditorForeground}"
             Padding="10"
             Visibility="Visible"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"/>

        <FlowDocumentReader x:Name="Reader"
                        Visibility="Collapsed"
                        ViewingMode="Page"
                        Background="{DynamicResource EditorBackground}"
                        Foreground="{DynamicResource EditorForeground}"/>

    </DockPanel>
    
</Window>

    