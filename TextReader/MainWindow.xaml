<Window x:Class="TextReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TextReader"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800"
        Closing="Window_Closing">

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">

                <MenuItem Header="Создать"
                          Click="New_Click"/>

                <MenuItem Header="Открыть"
                          Click="Open_Click"/>

                <MenuItem Header="Сохранить"
                          Click="Save_Click"/>

            </MenuItem>
        </Menu>
        <StackPanel Orientation="Horizontal"
            DockPanel.Dock="Top"
            Background="LightGray">

            <Button Content="B"
            FontWeight="Bold"
            Width="30"
            Click="Bold_Click"/>

            <Button Content="I"
            FontStyle="Italic"
            Width="30"
            Click="Italic_Click"/>

            <Button Content="U"
            Width="30"
            Click="Underline_Click"/>

            <Button Content="S"
            Width="30"
            Click="Strike_Click"/>
            
            <Button Content="Лево"
            Click="AlignLeft_Click"/>

            <Button Content="Центр"
            Click="AlignCenter_Click"/>

            <Button Content="Право"
            Click="AlignRight_Click"/>

            <Button Content="По ширине"
            Click="Justify_Click"/>

        </StackPanel>

        <RichTextBox x:Name="Editor"
             Padding="10"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"/>

    </DockPanel>
</Window>
