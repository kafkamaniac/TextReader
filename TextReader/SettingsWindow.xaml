<Window x:Class="TextReader.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Height="350"
        Width="600"
                        Background="{DynamicResource EditorBackground}"
                        Foreground="{DynamicResource EditorForeground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <ListBox x:Name="CategoryList"
                 SelectionChanged="CategoryList_SelectionChanged"
                        Background="{DynamicResource EditorBackground}"
                        Foreground="{DynamicResource EditorForeground}">

            <ListBoxItem Content="{DynamicResource Appearance}"
                         IsSelected="True"
                         Tag="Appearance"/>

            <ListBoxItem Content="{DynamicResource ReadMode}"
                         Tag="ReadingMode"/>

            <ListBoxItem Content="{DynamicResource Language}"
                         Tag="Language"/>

            <ListBoxItem Content="Озвучка"
                         Tag="Speech"/>

        </ListBox>

        <!-- RIGHT CONTENT AREA -->
        <Grid Grid.Column="1" Margin="10">

            <!-- APPEARANCE -->
            <StackPanel x:Name="AppearancePanel">

                <TextBlock Text="{DynamicResource Design}"
                           Margin="0,0,0,10"/>

                <ComboBox x:Name="ThemeBox">

                    <ComboBoxItem Content="{DynamicResource LightTheme}" Tag="Light"/>
                    <ComboBoxItem Content="{DynamicResource DarkTheme}" Tag="Dark"/>
                    <ComboBoxItem Content="{DynamicResource SepiaTheme}" Tag="Sepia"/>

                </ComboBox>

                <Button Content="{DynamicResource Apply}"
                        Margin="0,10,0,0"
                        Click="Apply_Click"/>

            </StackPanel>

            <!-- READING MODE -->
            <StackPanel x:Name="ReadingPanel"
                        Visibility="Collapsed">

                <TextBlock Text="{DynamicResource ReadMode}"
                           Margin="0,0,0,10"/>

                <ComboBox x:Name="ReadingModeBox">

                    <ComboBoxItem Content="{DynamicResource PageMode}" Tag="Page"/>
                    <ComboBoxItem Content="{DynamicResource TwoPageMode}" Tag="TwoPage"/>
                    <ComboBoxItem Content="{DynamicResource ScrollMode}" Tag="Scroll"/>

                </ComboBox>

                <Button Content="{DynamicResource Apply}"
                        Margin="0,10,0,0"
                        Click="ApplyReading_Click"/>

            </StackPanel>

            <!-- LANGUAGE -->
            <StackPanel x:Name="LanguagePanel"
                        Visibility="Collapsed">

                <TextBlock Text="{DynamicResource ChangeLang}"
                           Margin="0,0,0,10"/>

                <ComboBox x:Name="LanguageBox">

                    <ComboBoxItem Content="Русский"/>
                    <ComboBoxItem Content="English"/>

                </ComboBox>

                <Button Content="{DynamicResource Apply}"
                        Margin="0,10,0,0"
                        Click="ApplyLanguage_Click"/>

            </StackPanel>

            <!-- SPEECH -->
            <StackPanel x:Name="SpeechPanel"
            Visibility="Collapsed">

                <TextBlock Text="Озвучка"
               Margin="0,0,0,10"/>

                <!-- VOICE -->
                <TextBlock Text="Голос"/>

                <ComboBox x:Name="VoiceBox"
                          Margin="0,5,0,10"/>

                <!-- SPEED -->
                <TextBlock Text="Скорость"/>

                <Slider x:Name="SpeedSlider"
                        Minimum="-10"
                        Maximum="10"
                        Value="0"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"/>

                <Button Content="{DynamicResource Apply}"
                        Margin="0,10,0,0"
                        Click="ApplySpeech_Click"/>

            </StackPanel>

        </Grid>

    </Grid>
</Window>